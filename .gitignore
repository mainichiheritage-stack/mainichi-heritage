# --- Frontend (Next.js / Yarn / npm) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/coverage/
frontend/next-env.d.ts

# --- Backend (Django / Python) ---
backend/__pycache__/
backend/*.py[cod]
backend/db.sqlite3
backend/media/
backend/staticfiles/
backend/.venv/
backend/venv/
**/__pycache__/
*.py[cod]

# --- Environment Variables (最重要) ---
.env
.env.*
!**/.env.example
*.local
frontend/.env*
!frontend/.env.example
backend/.env

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS / IDE / Common ---
.DS_Store
.vscode/
.idea/
*.pem
.vercel
*.tsbuildinfo